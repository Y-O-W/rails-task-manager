<h1>Task List</h1>
<p>My tasks for today.</p>

<ul class="list-unstyled">
  <% @tasks.each do |task| %>
    <li class="list-group-item">
      <% if task.completed %>
        <i class="fa-regular fa-square-check"></i>
      <% else %>
        <i class="fa-regular fa-square"></i>
      <% end %>
      <label class="form-check-label" for="task-<%= task.id %>"><%= link_to task.title, task_path(task.id) %></label>
      <%= link_to "Delete", task_path(task.id), data: {turbo_method: :delete, turbo_confirm: "Delete #{task.title}?"} %>
    </li>
  <% end %>
</ul>

<%= link_to "Add new task", new_task_path %>
